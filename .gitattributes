# Auto detect text files and normalize line endings to LF
* text=auto

# Dart files
*.dart text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.wav binary
*.ttf binary
*.otf binary

# Gradle
*.gradle text eol=lf
gradlew text eol=lf

# Swift
*.swift text eol=lf
*.h text eol=lf
*.m text eol=lf

# Kotlin
*.kt text eol=lf
*.kts text eol=lf

# Markdown
*.md text eol=lf

# JSON
*.json text eol=lf

# YAML
*.yaml text eol=lf
*.yml text eol=lf

# XML
*.xml text eol=lf
